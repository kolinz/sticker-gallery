# アプリケーション環境（development / staging / production）
APP_ENV=development

# Express サーバーのポート番号
PORT=3000

# SQLite データベースファイルのパス
DB_PATH=./db/stickers.db

# アップロード画像の保存ディレクトリ
UPLOAD_DIR=./uploads

# JWT 署名シークレット（production では 32 文字以上のランダム文字列に変更すること）
JWT_SECRET=change-me-in-production

# JWT 有効期限（秒）。28800 = 8 時間
JWT_EXPIRES_IN=28800

# 初回マイグレーション時に作成される管理者アカウント
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=changeme

# 最新カリキュラム年度（授業の「最新」バッジ判定に使用）
LATEST_CURRICULUM_YEAR=2025

# Vite 開発サーバーのポート番号（デフォルト: 5173）
VITE_PORT=5173

# バックエンドのホスト名（Vite プロキシ用。デフォルト: localhost）
SERVER_HOST=localhost

# 最新カリキュラム年度（フロントエンド側でも参照する場合は VITE_ プレフィックスを追加）
VITE_LATEST_CURRICULUM_YEAR=2025
